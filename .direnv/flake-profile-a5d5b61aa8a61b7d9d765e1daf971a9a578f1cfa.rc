preferLocalBuild='1'
export preferLocalBuild
prefix='/home/alex/Projects/integra/outputs/out'
declare -a propagatedBuildDepFiles=('propagated-build-build-deps' 'propagated-native-build-inputs' 'propagated-build-target-deps' )
propagatedBuildInputs=' /nix/store/ybqwc9iz34hblrwcvsfh1q08ac9g1xr6-aeson-2.2.4.1    /nix/store/fv3dcvrzx2w9dh4wxk8mpzhgb1598wqn-http-types-0.12.4  /nix/store/9i1q625pdygn236fcdzz7qnraf8b6xj9-scotty-0.22  /nix/store/d83c8v7d1r4bpfbn1m99axjm0k7x01vk-warp-3.4.9'
