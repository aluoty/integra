---
// Integra Web Calculator — Rust WASM + Astro
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Integra</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #1a1a2e; color: #e0e0e0; font: 14px/1.5 'Consolas','Monaco','Courier New',monospace; }
    #terminal { max-width: 800px; margin: 0 auto; padding: 20px; height: 100vh; display: flex; flex-direction: column; }
    #output { flex: 1; overflow-y: auto; padding: 10px 0; white-space: pre-wrap; word-break: break-all; }
    #output .line { padding: 2px 0; }
    #output .line.input { color: #7ec8e3; }
    #output .line.result { color: #a8e6cf; }
    #output .line.error { color: #ff6b6b; }
    #output .line.info { color: #ffd93d; }
    #output .line.deriv { color: #c792ea; }
    #output .svg-container { margin: 8px 0; }
    #output .svg-container svg { max-width: 100%; height: auto; border: 1px solid #333; border-radius: 4px; }
    #input-row { display: flex; align-items: center; gap: 8px; padding-top: 10px; border-top: 1px solid #333; }
    #input-row .prompt { color: #7ec8e3; font-weight: bold; }
    #input { flex: 1; background: #16213e; border: 1px solid #333; color: #e0e0e0; padding: 8px 12px; font: 14px/1.5 'Consolas','Monaco','Courier New',monospace; border-radius: 4px; outline: none; }
    #input:focus { border-color: #7ec8e3; }
  </style>
</head>
<body>
  <div id="terminal">
    <div id="output"></div>
    <div id="input-row">
      <span class="prompt">λ</span>
      <input id="input" type="text" autofocus placeholder="Type an expression or :help" spellcheck="false" autocomplete="off" />
    </div>
  </div>
  <script>
    import '../repl.ts';
  </script>
</body>
</html>
